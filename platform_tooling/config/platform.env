# ============================== ==============================
# Platform Configuration
# ============================== ==============================
# This file is the single source of truth for platform tooling variables.
# Scripts will explicitly declare which variables they need from this file.

# The unique name of this specific repository (used for state bucket uniqueness)
REPO_NAME="landing-zone"

GCP_PROJECT_ID="ttl-landing-zone"
GCP_REGION="europe-west1"

STATE_BUCKET_PREFIX="tfstate"
STATE_PREFIX="env"
STATE_REGISTRY_PREFIX="registry"

# OPTIONAL: Override the auto-computed bucket name if using a pre-existing bucket.
# If commented out or empty, the script will compute: tfstate-{REPO_NAME}-{ENV}
# BACKEND_BUCKET_NAME="my-pre-existing-custom-bucket"
